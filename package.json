{
  "name": "friendslist",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A private friend tier-list with predictions and geographic pairings",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file-if-exists=.env.local server/index.ts",
    "build": "tsc -b && vite build",
    "build:prod": "npm run build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview",
    "server": "tsx --env-file-if-exists=.env.local server/index.ts",
    "geocode": "tsx --env-file-if-exists=.env.local server/scripts/geocode.ts",
    "seed-placeholders": "tsx --env-file-if-exists=.env.local server/scripts/seed-placeholder-photos.ts",
    "prototype": "npx serve prototype"
  },
  "keywords": [
    "tier-list",
    "friends",
    "private"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
