# Copy this file to .env.local for local development.
# In production (Render), set these in the Environment Variables dashboard.
# .env.local is gitignored — never commit real secrets.

# Admin login password (required)
ADMIN_PASSWORD=change-me

# Turso database — required in production.
# Omit locally to use a local SQLite file (server/data/local.db).
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Set automatically by Render. Leave unset locally (defaults to 3001).
# PORT=3001
